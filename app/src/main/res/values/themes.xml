<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.VideoCraft" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text -->
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Chip style -->
        <item name="chipStyle">@style/AppChipStyle</item>
    </style>

    <!-- Chip style for dark theme -->
    <style name="AppChipStyle" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipBackgroundColor">@color/bg_surface_3</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <!-- Splash screen -->
    <style name="Theme.VideoCraft.Splash" parent="Theme.VideoCraft">
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>
</resources>
