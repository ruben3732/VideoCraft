<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/bg_surface_2"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_caption_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00 → 0:02"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:fontFamily="monospace" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_caption_language"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HINGLISH"
                android:textSize="10sp"
                android:textColor="@color/secondary"
                android:background="@drawable/bg_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_caption_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Caption text here"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_caption"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Edit"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_caption"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Delete"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:iconTint="@color/error" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
