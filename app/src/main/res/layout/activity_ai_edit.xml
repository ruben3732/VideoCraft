<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/bg_surface">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ AI Smart Edit"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Hero button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ai_edit"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="⚡ 1-Click AI Edit"
                android:textSize="20sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                android:backgroundTint="@color/accent"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Automatically removes pauses, fillers, and tightens your video"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Progress / status -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready"
                android:textColor="@color/text_secondary"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- Results summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tv_saved_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️ Analyze first"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_silence_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔇 Pauses: —"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_filler_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗣️ Fillers: —"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_broll_keywords"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📸 B-roll: —"
                    android:textColor="@color/secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Fine-tuned controls -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fine-tune Options"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Remove silence -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔇 Remove Silence"
                        android:textColor="@color/text_primary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_remove_silence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Remove fillers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🗣️ Remove Filler Words"
                        android:textColor="@color/text_primary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_remove_fillers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Add B-roll -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📸 Suggest B-roll"
                        android:textColor="@color/text_primary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_add_broll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Auto captions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💬 Auto-Captions"
                        android:textColor="@color/text_primary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_add_captions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Sound FX -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔊 Add Sound FX"
                        android:textColor="@color/text_primary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_add_sound_fx"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- Silence threshold slider -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Silence Sensitivity"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_silence_threshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="100"
                android:valueTo="1000"
                android:value="300"
                android:stepSize="50"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minimum Pause to Cut (seconds)"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_min_pause"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.2"
                android:valueTo="2.0"
                android:value="0.4"
                android:stepSize="0.1"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_apply_settings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Apply Settings"
                android:textSize="15sp"
                app:cornerRadius="12dp"
                android:backgroundTint="@color/primary" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
